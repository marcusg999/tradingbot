# ==========================================================================
# momentum-bot configuration — copy to .env and fill in.
# The .env file is gitignored. NEVER commit real keys.
# ==========================================================================

# --- Alpaca credentials ----------------------------------------------------
# Get PAPER keys at https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=your_paper_key_here
ALPACA_API_SECRET=your_paper_secret_here

# --- SAFETY GATE (defaults are safe: paper trading) ------------------------
# Live trading requires BOTH of the next two lines to be set exactly as shown.
# If either is missing/wrong, the bot runs on the PAPER endpoint and warns.
TRADING_MODE=paper
I_UNDERSTAND_REAL_MONEY=no
#   ...to go live (only after weeks of profitable paper trading):
#   TRADING_MODE=live
#   I_UNDERSTAND_REAL_MONEY=yes

# --- Universe --------------------------------------------------------------
# Comma-separated Alpaca crypto pairs. BTC/USD, ETH/USD are the v1 core.
# You can explore volatile alts Alpaca lists (e.g. SOL/USD, DOGE/USD).
SYMBOLS=BTC/USD,ETH/USD
TIMEFRAME_HOURS=1

# --- Strategy --------------------------------------------------------------
EMA_FAST=20
EMA_SLOW=50
RSI_PERIOD=14
RSI_LOW=50
RSI_HIGH=70

# --- Risk management (non-negotiable defaults) -----------------------------
RISK_PER_TRADE=0.02        # risk 2% of equity per trade
HARD_STOP_PCT=0.03         # hard stop 3% below entry
TRAIL_ACTIVATE_PCT=0.04    # arm trailing stop after +4%
TRAIL_PCT=0.025            # trail by 2.5%
DAILY_KILL_PCT=0.05        # halt after -5% on the day
MAX_EXPOSURE_PCT=0.50      # at most 50% of equity deployed total
MAX_ORDER_PCT=0.25         # reject any single order > 25% of equity
MAX_DATA_STALENESS_SEC=300 # reject signals on data older than 5 min
MIN_NOTIONAL=1.0

# --- Runtime ---------------------------------------------------------------
POLL_INTERVAL_SEC=60
STATE_DB_PATH=state.db
TRADES_CSV_PATH=trades.csv

# --- Logging ---------------------------------------------------------------
LOG_LEVEL=INFO
LOG_JSON=false

# --- Notifications (optional) ----------------------------------------------
# Leave blank to disable. Discord webhook OR Telegram bot token + chat id.
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
